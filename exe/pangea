#!/usr/bin/env ruby
# frozen_string_literal: true

# Pangea CLI — synthesize Ruby templates to Terraform JSON and run tofu
#
# Usage:
#   pangea plan template.rb --namespace development
#   pangea apply template.rb --namespace production
#   pangea destroy template.rb --namespace development
#   pangea synth template.rb  # synthesis only, no tofu
#   pangea output template.rb --namespace development  # tofu output -json

require 'json'
require 'yaml'
require 'fileutils'

# Parse arguments
operation = ARGV.shift
if operation.nil? || %w[--help -h].include?(operation)
  $stderr.puts <<~USAGE
    Usage: pangea <operation> <template.rb> [--namespace <ns>]

    Operations:
      plan     Synthesize + tofu plan
      apply    Synthesize + tofu apply -auto-approve
      destroy  Synthesize + tofu destroy -auto-approve
      synth    Synthesize only (write JSON, no tofu)
      output   Run tofu output -json on existing workspace
      init     Synthesize + tofu init (no plan/apply)

    Options:
      --namespace, -n   Namespace (overrides pangea.yml default_namespace)
  USAGE
  exit(operation.nil? ? 1 : 0)
end

template_file = ARGV.shift
unless template_file
  $stderr.puts "Error: template file required"
  exit 1
end

unless File.exist?(template_file)
  $stderr.puts "Error: template file not found: #{template_file}"
  exit 1
end

# Parse --namespace flag
namespace = nil
ARGV.each_with_index do |arg, i|
  if %w[--namespace -n].include?(arg)
    namespace = ARGV[i + 1]
    break
  end
end

# Resolve namespace from pangea.yml if not provided
template_dir = File.dirname(File.expand_path(template_file))
if namespace.nil?
  pangea_yml = File.join(template_dir, 'pangea.yml')
  if File.exist?(pangea_yml)
    config = YAML.safe_load(File.read(pangea_yml)) || {}
    namespace = config['default_namespace']
  end
end

namespace ||= 'default'

# Template name from filename (without extension)
template_name = File.basename(template_file, '.rb')

# Workspace directory for tofu state
home = ENV['HOME'] || '.'
workspace_dir = File.join(home, '.pangea', 'workspaces', namespace, template_name)
FileUtils.mkdir_p(workspace_dir)

# For synth-only or tofu operations, check what we need
if operation == 'output'
  Dir.chdir(workspace_dir) do
    exec('tofu', 'output', '-json')
  end
end

# ── Synthesis ──────────────────────────────────────────────────────────
$stderr.puts "[pangea] Synthesizing #{template_file} [namespace: #{namespace}]"

# Load pangea-core and provider gems via bundler's environment
begin
  require 'terraform_synthesizer'
rescue LoadError
  require 'abstract_synthesizer'
end

# Load the template content
template_content = File.read(template_file)

# Create synthesizer and evaluate template
synth = TerraformSynthesizer.new

# The template uses `template :name do ... end` DSL.
# We need to capture the block and evaluate it on the synthesizer.
# Override Kernel#template to capture the block.
template_block = nil
define_method(:template) do |_name, &block|
  template_block = block
end

# Evaluate the template file in a context where `template` captures the block
eval(template_content, binding, File.expand_path(template_file)) # rubocop:disable Security/Eval

if template_block
  synth.instance_eval(&template_block)
else
  $stderr.puts "[pangea] Warning: no template block found in #{template_file}"
  $stderr.puts "[pangea] Trying direct evaluation..."
  synth.instance_eval(template_content, File.expand_path(template_file))
end

# Load namespace config for backend block
pangea_yml_path = File.join(template_dir, 'pangea.yml')
root_pangea_yml = Dir.pwd == template_dir ? nil : File.join(Dir.pwd, 'pangea.yml')

backend_config = {}
[root_pangea_yml, pangea_yml_path].compact.each do |yml_path|
  next unless File.exist?(yml_path)

  config = YAML.safe_load(File.read(yml_path)) || {}

  # Check namespace-specific state config
  ns_config = config.dig('namespaces', namespace)
  if ns_config
    state = ns_config['state'] || {}
    state_type = state['type'] || 's3'

    if state_type == 'local'
      backend_config = { 'local' => { 'path' => state['path'] || 'terraform.tfstate' } }
    elsif state_type == 's3'
      s3_defaults = config.dig('state', 's3') || {}
      backend_config = {
        's3' => {
          'bucket' => state['bucket'] || s3_defaults['bucket'],
          'key' => "#{state['key'] || s3_defaults['key']}/#{template_name}/terraform.tfstate",
          'region' => state['region'] || s3_defaults['region'] || 'us-east-1',
          'dynamodb_table' => state['dynamodb_table'] || s3_defaults['dynamodb_table'],
          'encrypt' => state.fetch('encrypt', s3_defaults.fetch('encrypt', true)),
        }.compact,
      }
    end
  end
end

# Get the synthesis result and inject backend
manifest = synth.synthesis
manifest = JSON.parse(JSON.generate(manifest)) # normalize symbol keys to strings

# Inject backend config into terraform block
unless backend_config.empty?
  manifest['terraform'] ||= {}
  manifest['terraform']['backend'] = backend_config
end

terraform_json = JSON.pretty_generate(manifest)

# Write terraform JSON to workspace
output_path = File.join(workspace_dir, "#{template_name}.tf.json")
File.write(output_path, terraform_json)
$stderr.puts "[pangea] Wrote #{output_path}"

if operation == 'synth'
  $stdout.puts terraform_json
  exit 0
end

# ── Tofu Operations ───────────────────────────────────────────────────
Dir.chdir(workspace_dir) do
  # Always init first
  $stderr.puts "[pangea] Running tofu init..."
  unless system('tofu', 'init', '-input=false', '-no-color', '-reconfigure')
    $stderr.puts "[pangea] tofu init failed"
    exit 1
  end

  case operation
  when 'init'
    $stderr.puts "[pangea] Init complete."
  when 'plan'
    $stderr.puts "[pangea] Running tofu plan..."
    success = system('tofu', 'plan', '-input=false', '-no-color')
    exit(success ? 0 : 1)
  when 'apply'
    $stderr.puts "[pangea] Running tofu apply..."
    success = system('tofu', 'apply', '-auto-approve', '-input=false', '-no-color')
    exit(success ? 0 : 1)
  when 'destroy'
    $stderr.puts "[pangea] Running tofu destroy..."
    success = system('tofu', 'destroy', '-auto-approve', '-input=false', '-no-color')
    exit(success ? 0 : 1)
  else
    $stderr.puts "Error: unknown operation '#{operation}'"
    exit 1
  end
end
